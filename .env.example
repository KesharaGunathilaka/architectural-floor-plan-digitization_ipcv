# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Dataset Paths ───────────────────────────────────
# Absolute path to your downloaded cubicasa5k folder
CUBICASA_ROOT=C:/Users/YourName/datasets/cubicasa5k

# On Ubuntu it would be:
# CUBICASA_ROOT=/home/yourname/datasets/cubicasa5k

# ── Project Root (usually auto-detected, set if needed)
PROJECT_ROOT=

# ── Training Device ─────────────────────────────────
# Options: "cpu", "cuda", "cuda:0"
DEVICE=cpu

# On Ubuntu with RTX 5090:
# DEVICE=cuda:0

# ── Experiment Tracking ─────────────────────────────
# Optional: Weights & Biases API key (add later)
WANDB_API_KEY=