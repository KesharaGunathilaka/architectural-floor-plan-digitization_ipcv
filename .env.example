# ── Dataset Paths ───────────────────────────────────
# Absolute path to your downloaded cubicasa5k folder.
# Download CubiCasa5k separately: https://github.com/CubiCasa/CubiCasa5k
CUBICASA_ROOT=/path/to/cubicasa5k

# ── Project Root (usually auto-detected, set if needed)
PROJECT_ROOT=

# ── Training Device ─────────────────────────────────
# Options: "cpu", "cuda", "cuda:0"
DEVICE=cuda:0
