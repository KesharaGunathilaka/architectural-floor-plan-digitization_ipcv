# ── Python ──────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Virtual Environments ────────────────────────────
.venv/
venv/
env/
ENV/

# ── Jupyter ─────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Data — never commit raw dataset, images, or processed files ──
# Everything under data/ is a derived/machine-local artifact regenerated
# by the src/data scripts (dataset_stats, select_subset, convert_annotations).
/data/

# ── Model Weights & Training Artifacts ──────────────
runs/
models/
*.pt
*.pth
*.onnx
*.torchscript
!runs/.gitkeep

# ── Outputs ─────────────────────────────────────────
outputs/*
exports/*
!outputs/.gitkeep
logs/*
!logs/.gitkeep

# ── Secrets ─────────────────────────────────────────
.env
*.env

# ── OS ──────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Coverage & Testing ──────────────────────────────
.coverage
htmlcov/
.pytest_cache/

# git
.github/
.gitkeep